#!/usr/bin/env bash
# =============================================================================
# review — Local code review powered by Ollama
#
# Usage:
#   review                        # review staged changes
#   review --branch main          # review current branch vs main
#   review --diff path/to/my.diff # review an existing diff file
#   review --commit HEAD~3..HEAD  # review a commit range
#   review --hash abc1234         # review a single commit by hash
#   review --file src/foo.py      # review a single file (unstaged OK)
#
# Options:
#   --branch <base>      Compare current branch against <base> (default: main)
#   --diff   <file>      Use a pre-generated diff file
#   --commit <range>     Git commit range, e.g. HEAD~1..HEAD
#   --hash   <sha>       Review a single commit by its hash (short or full)
#   --file   <path>      Review a single file against HEAD
#   --model  <name>      Ollama model (default: qwen3:latest)  ← set below
#   --lang   <language>  Response language (default: English)
#   --out    <file>      Save review to file in addition to stdout
#   --no-color           Disable colour output
#   -h, --help           Show this help
# =============================================================================

set -euo pipefail

# ── Defaults ─────────────────────────────────────────────────────────────────
OLLAMA_URL="http://localhost:11434"
MODEL="qwen3.5:latest"
RESPONSE_LANGUAGE="English"
OUTPUT_FILE=""
USE_COLOR=true

# ── Colour helpers ────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

color() { $USE_COLOR && printf "%b%s%b\n" "$1" "$2" "$RESET" || echo "$2"; }
info()    { color "$CYAN"   "ℹ  $*"; }
success() { color "$GREEN"  "✔  $*"; }
warn()    { color "$YELLOW" "⚠  $*"; }
error()   { color "$RED"    "✖  $*" >&2; }
header()  { color "$BOLD"   "$*"; }

die() { error "$*"; exit 1; }

# ── Dependency checks ─────────────────────────────────────────────────────────
require() { command -v "$1" &>/dev/null || die "Required tool not found: $1"; }
require git
require qwen

# ── Argument parsing ──────────────────────────────────────────────────────────
MODE="staged"          # staged | branch | diff | commit | hash | file
BASE_BRANCH="main"
DIFF_FILE=""
COMMIT_RANGE=""
COMMIT_HASH=""
SINGLE_FILE=""

usage() {
  grep '^#' "$0" | grep -v '#!/' | sed 's/^# \{0,2\}//'
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --branch)  MODE="branch";  BASE_BRANCH="${2:?--branch requires a value}"; shift 2 ;;
    --diff)    MODE="diff";    DIFF_FILE="${2:?--diff requires a path}";       shift 2 ;;
    --commit)  MODE="commit";  COMMIT_RANGE="${2:?--commit requires a range}"; shift 2 ;;
    --hash)    MODE="hash";    COMMIT_HASH="${2:?--hash requires a commit hash}"; shift 2 ;;
    --file)    MODE="file";    SINGLE_FILE="${2:?--file requires a path}";     shift 2 ;;
    --model)   MODEL="${2:?--model requires a value}";                          shift 2 ;;
    --lang)    RESPONSE_LANGUAGE="${2:?--lang requires a value}";               shift 2 ;;
    --out)     OUTPUT_FILE="${2:?--out requires a path}";                       shift 2 ;;
    --no-color) USE_COLOR=false;                                                shift   ;;
    -h|--help) usage ;;
    *) die "Unknown argument: $1  (try --help)" ;;
  esac
done

# ── Collect the diff ──────────────────────────────────────────────────────────
get_diff() {
  local diff_content=""

  case "$MODE" in
    staged)
      info "Collecting staged changes …"
      diff_content=$(git diff --cached 2>/dev/null)
      if [[ -z "$diff_content" ]]; then
        # Fall back to unstaged
        warn "No staged changes found — falling back to unstaged (working tree) diff."
        diff_content=$(git diff 2>/dev/null)
      fi
      ;;
    branch)
      info "Comparing current branch against '$BASE_BRANCH' …"
      local current
      current=$(git rev-parse --abbrev-ref HEAD)
      [[ "$current" != "$BASE_BRANCH" ]] || die "Current branch IS '$BASE_BRANCH'; nothing to diff."
      diff_content=$(git diff "$BASE_BRANCH"...HEAD 2>/dev/null)
      ;;
    diff)
      [[ -f "$DIFF_FILE" ]] || die "Diff file not found: $DIFF_FILE"
      info "Reading diff from file: $DIFF_FILE …"
      diff_content=$(cat "$DIFF_FILE")
      ;;
    commit)
      info "Reviewing commit range: $COMMIT_RANGE …"
      diff_content=$(git diff "$COMMIT_RANGE" 2>/dev/null)
      ;;
    hash)
      # Validate the hash resolves to a real commit
      git rev-parse --verify "${COMMIT_HASH}^{commit}" &>/dev/null \
        || die "Not a valid commit hash: $COMMIT_HASH"
      local full_hash subject author date_str
      full_hash=$(git rev-parse "$COMMIT_HASH")
      subject=$(git log -1 --format="%s" "$full_hash")
      author=$(git log -1 --format="%an <%ae>" "$full_hash")
      date_str=$(git log -1 --format="%ad" --date=short "$full_hash")
      info "Reviewing commit $full_hash …"
      info "  Author : $author"
      info "  Date   : $date_str"
      info "  Message: $subject"
      # Prepend commit metadata so the model has full context
      diff_content="$(printf 'Commit : %s\nAuthor : %s\nDate   : %s\nMessage: %s\n\n' \
        "$full_hash" "$author" "$date_str" "$subject")"
      diff_content+=$(git show --format="" "$full_hash" 2>/dev/null)
      ;;
    file)
      [[ -f "$SINGLE_FILE" ]] || die "File not found: $SINGLE_FILE"
      info "Reviewing single file: $SINGLE_FILE …"
      diff_content=$(git diff HEAD -- "$SINGLE_FILE" 2>/dev/null)
      if [[ -z "$diff_content" ]]; then
        warn "No git diff for '$SINGLE_FILE' — showing full file content."
        diff_content="--- /dev/null
+++ $SINGLE_FILE
$(cat "$SINGLE_FILE" | sed 's/^/+/')"
      fi
      ;;
  esac

  if [[ -z "$diff_content" ]]; then
    die "No changes found to review."
  fi

  echo "$diff_content"
}

# ── Summarise the diff for context ───────────────────────────────────────────
diff_summary() {
  local diff="$1"
  local files added removed
  files=$(echo "$diff"   | grep -c '^diff --git' || true)
  added=$(echo "$diff"   | grep -c '^+'          || true)
  removed=$(echo "$diff" | grep -c '^-'          || true)
  echo "Files changed: $files | Lines added: $added | Lines removed: $removed"
}

# ── Build the review prompt (mirrors the action's prompt structure) ────────────
build_prompt() {
  local diff="$1"
  local summary
  summary=$(diff_summary "$diff")

  {
  cat <<PROMPT
You are an expert code reviewer. Analyse the following code diff and provide a thorough, actionable review.

## Diff Statistics
${summary}

## Code Diff
\`\`\`diff
${diff}
\`\`\`

## Review Instructions
Please structure your review with the following sections:

### Formatting

Write in markdown with proper headings. Your format is being parsed by \`glow\`

### 1. Summary
A concise overview of what these changes do.

### 2. Risk Score
Rate the overall risk of these changes on a scale of 1–5:
- 1 = Trivial / safe
- 2 = Low risk
- 3 = Moderate risk — needs careful testing
- 4 = High risk — potential bugs or breaking changes
- 5 = Critical — do not merge without major rework

State the score as: **Risk Score: X/5**

### 3. Issues Found
List bugs, logic errors, security problems, or correctness issues. For each:
- **Severity**: Critical | High | Medium | Low
- **File & Line** (if identifiable)
- **Description** of the problem
- **Suggested Fix**

If no issues are found, state "No issues found."

### 4. Code Quality
Comment on readability, naming conventions, complexity, and adherence to best practices.

### 5. Performance & Security
Note any performance concerns or security vulnerabilities (e.g. injection, improper auth, resource leaks).

### 6. Positive Highlights
What is done well in these changes?

### 7. Recommended Actions
A prioritised, numbered list of concrete next steps before merging.

PROMPT

  # Append translation instruction outside the heredoc, using proper bash
  if [[ "$RESPONSE_LANGUAGE" != "English" ]]; then
    printf '\nPlease write your entire review in %s, but keep all technical terms, code identifiers, file names, and error messages in English.\n' "$RESPONSE_LANGUAGE"
  fi
  } # end subshell capture
}

# ── Truncate very large diffs to avoid context limits ─────────────────────────
MAX_DIFF_CHARS=24000   # ~6 k tokens; adjust for your model's context window

truncate_diff() {
  local diff="$1"
  if (( ${#diff} > MAX_DIFF_CHARS )); then
    warn "Diff is large (${#diff} chars). Truncating to $MAX_DIFF_CHARS chars to fit context window."
    warn "Consider reviewing specific files with --file or a narrower --commit range."
    diff="${diff:0:$MAX_DIFF_CHARS}"$'\n\n... [TRUNCATED — diff was too large] ...'
  fi
  echo "$diff"
}

# ── Print the review ──────────────────────────────────────────────────────────
print_review() {
  local review="$1"

  echo ""
  echo "$review"
  echo ""
}

# ── Optional: save to file ────────────────────────────────────────────────────
save_review() {
  local review="$1"
  if [[ -n "$OUTPUT_FILE" ]]; then
    {
      echo "# Code Review — $(date '+%Y-%m-%d %H:%M:%S')"
      echo ""
      echo "$review"
    } > "$OUTPUT_FILE"
    success "Review saved to: $OUTPUT_FILE"
  fi
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
  header ""
  header "  🔍  Local Code Review"
  header ""

  local raw_diff diff prompt review
  raw_diff=$(get_diff)
  diff=$(truncate_diff "$raw_diff")

  success "Diff collected. $(diff_summary "$diff")"

  prompt=$(build_prompt "$diff")
  info "Sending diff to qwen…"
  review=$(cd /home/josh/bin && ./qwen --raw "$prompt" | glow -w 200 -s dark -)

  if [[ -z "$review" ]]; then
    die "qwen returned an empty response. Check that Ollama is running."
  fi

  print_review "$review"
  save_review "$review"
}

main "$@"
